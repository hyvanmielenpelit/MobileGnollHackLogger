@page
@model IndexModel
@{
    ViewData["Title"] = "";
}

<div class="text-center">
    <h1 class="hero-title">GNOLLHACK</h1>
    <p class="fw-light">Top Score Recording &bull; Bones Sharing &bull; NetHack Scoreboard Support &bull; Junethack Support &bull; Statistics</p>
    <hr class="separator" />
    
@if (User?.Identity?.IsAuthenticated ?? false)
    {
        if (Model.GameLogCount > 0)
        {
            <div class="mb-4">
                <h2 class="mt-3">Your GnollHack Statistics</h2>
            </div>
            
            <div class="center-box text-start">
                <div class="card border-secondary card-glass h-100">
                    <div class="card-body text-center">
                        <h4 class="card-title text-uppercase mb-3 hero-step-title">
                            Played Games
                        </h4>
                        <div class="display-1 fw-bold mb-3 title">
                            @Model.GameLogCount
                        </div>
                        <p class="text-muted">You have successfully posted @Model.GameLogCount game@(Model.GameLogCount == 1 ? "" : "s") to the server.</p>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="mb-4">
                <h5 class="text-success"><i class="bi bi-patch-check-fill me-2"></i>Thank you for registering a GnollHack account!</h5>
                <h2 class="mt-3">Now The Last Step</h2>
            </div>
            
            <div class="center-box text-start">
                <div class="card border-secondary card-glass h-100">
                    <div class="card-body">
                        <h4 class="card-title text-center text-uppercase mb-3 hero-step-title">
                            Connect In-App
                        </h4>
                        <div class="text-center mb-3">
                            <img src="/img/gear-glow-v2.webp" alt="Connect In-App" class="hero-icon" />
                        </div>
                        <h5 class="card-title text-center text-uppercase mb-3 hero-step-subtitle">
                            <i class="bi bi-plug-fill me-2"></i>Link Your Account
                        </h5>
                        <ol class="card-text">
                            <li>Go to <em>Settings</em> in the game menu.</li>
                            <li>Locate the <em>Server Posting</em> section.</li>
                            <li>Enter your registered <em>User Name</em> and <em>Password</em> to the respective fields.</li>
                            <li>Enable <em>Post Top Scores</em> and/or <em>Post Bones Files</em>.</li>
                        </ol>
                        <p class="text-center text-muted small mt-3 mb-0" style="font-style:italic;">
                            (If you have already entered these credentials in the app, you can safely ignore these instructions.)
                        </p>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <h2 class="title mb-4" style="font-size: calc(1.4575rem + 0.99vw);">Getting Started</h2>
        <div class="row g-4 justify-content-center text-start">
            <div class="col-12 col-md-6">
                <div class="card border-secondary card-glass h-100">
                    <div class="card-body d-flex flex-column justify-content-between">
                        <div>
                            <h4 class="card-title text-center text-uppercase mb-3 hero-step-title">
                                1. Create Account
                            </h4>
                            <div class="text-center mb-3">
                                <img src="/img/scroll-glow.webp" alt="Create Account" class="hero-icon" />
                            </div>
                            <h5 class="card-title text-center text-uppercase mb-3 hero-step-subtitle">
                                <i class="bi bi-person-plus-fill me-2"></i>Join the Ranks
                            </h5>
                            <p class="card-text text-muted mb-4">
                                Create your global GnollHack profile to sync score records, participate in tournaments, and share bones files.
                            </p>
                        </div>
                        <div>
                            <a href="/Identity/Account/Register" class="btn btn-hero-register w-100">
                                <span><i class="bi bi-arrow-right-circle me-1"></i> Register Username</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="card border-secondary card-glass h-100">
                    <div class="card-body">
                        <h4 class="card-title text-center text-uppercase mb-3 hero-step-title">
                            2. Connect In-App
                        </h4>
                        <div class="text-center mb-3">
                            <img src="/img/gear-glow-v2.webp" alt="Connect In-App" class="hero-icon" />
                        </div>
                        <h5 class="card-title text-center text-uppercase mb-3 hero-step-subtitle">
                            <i class="bi bi-plug-fill me-2"></i>Link Your Account
                        </h5>
                        <ol class="card-text">
                            <li>Go to <em>Settings</em> in the game menu.</li>
                            <li>Locate the <em>Server Posting</em> section.</li>
                            <li>Enter your registered <em>User Name</em> and <em>Password</em> to the respective fields.</li>
                            <li>Enable <em>Post Top Scores</em> and/or <em>Post Bones Files</em>.</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
