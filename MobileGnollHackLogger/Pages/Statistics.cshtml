@page
@using System.Globalization
@model MobileGnollHackLogger.Pages.StatisticsModel
@{
    var modeText = "All Modes";
    if (!string.IsNullOrEmpty(Model.Mode) && GnollHackHelper.Modes.ContainsKey(Model.Mode))
    {
        modeText = GnollHackHelper.Modes[Model.Mode] + " Mode";
    }
    ViewData["Title"] = Model.Title;
    ViewData["ContainerClass"] = "xxlMaxWidth";
    ViewData["MainClass"] = "xxlMaxWidth";

    var allGamesCount = Model.GameLogs != null ? Model.GameLogs.Count() : 0;
    var allAscensionCount = Model.GameLogs != null ? Model.GameLogs.Where(gl => gl.DeathText == "ascended").Count() : 0;
}

<div class="rpg-header mt-3">
    <div class="ornament"></div>
    <h1 class="mb-0" style="font-family: 'Cinzel', serif;">Statistics</h1>
    <div class="ornament"></div>
</div>
<div class="text-center rpg-subtitle">
    WIN RATE PER ROLE AND DIFFICULTY IN @modeText.ToUpper()
</div>

<div class="d-flex flex-wrap justify-content-center gap-2 gap-md-4 mb-4 mt-3">
    <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
        <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-controller me-1"></i>Gameplay Mode</h6>
        <div class="btn-group" role="group">
            @if(!string.IsNullOrEmpty(Model.Mode))
            {
                <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="/Statistics">All Modes</a>
            }
            else
            {
                <span class="btn btn-sm btn-primary active">All Modes</span>
            }
            @foreach (var mode in Model.DisplayModes)
            {
                @if (Model.Mode != mode)
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="/Statistics?mode=@mode">@GnollHackHelper.Modes[mode]</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">@GnollHackHelper.Modes[mode]</span>
                }
            }
        </div>
    </div>
</div>

<h6 class="text-center text-muted-small pb-3">G = Games, A = Ascensions, Min @Model.MinTurns Turns, Less Than @Model.YearString Old</h6>

<div class="rpg-leaderboard-card">
    <div class="table-responsive">
        <table id="statisticsTable" class="rpg-table">
        <thead>
            <tr>
                <th>
                    Difficulty
                </th>
                @foreach(var role in GnollHackHelper.Roles)
                {
                    <th class="text-center">@GnollHackHelper.GetRoleText(role, "Mal")</th>
                }
                <th class="text-center matrix-border-start">All Roles</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var difficulty in GnollHackHelper.Difficulties)
            {
                <tr>
                    @{
                        long allDiffGames = Model.GameLogs != null ? Model.GameLogs.Where(gl => gl.Difficulty == difficulty.Key).Count() : 0; ;
                        long allDiffAscensions = Model.GameLogs != null ? Model.GameLogs.Where(gl => gl.Difficulty == difficulty.Key && gl.DeathText == "ascended").Count() : 0;
                    }
                    <td class="w-diff border-bottom-0"><h6>@difficulty.Value</h6></td>
                    @foreach (var role in GnollHackHelper.Roles)
                    {                        
                        long games = 0;
                        long ascensions = 0;

                        if (Model.GroupByRole != null)
                        {
                            var grouping = Model.GroupByRole.FirstOrDefault(gr => gr.Key == role);
                            if (grouping != null)
                            {
                                games = grouping.Where(g => g.Difficulty == difficulty.Key).LongCount();
                            }
                        }
                        if (Model.GroupByRoleAscended != null)
                        {
                            var grouping = Model.GroupByRoleAscended.FirstOrDefault(gr => gr.Key == role);
                            if (grouping != null)
                            {
                                ascensions = grouping.Where(g => g.Difficulty == difficulty.Key).LongCount();
                            }
                        }
                        string? darkeningClass = games > 0 ? null : "text-muted";

                        <td class="w-role text-center border-bottom-0 @darkeningClass">
                            <h5>@(games > 0 ? ((double)ascensions / (double)games).ToPercentageString(true) : "N/A")</h5>
                            <div class="cell-stats mx-auto">
                                <div class="stat-pill">
                                    <div class="top-row">
                                        <span class="label">G</span>
                                        <span class="val">@games</span>
                                    </div>
                                    @if (allDiffGames > 0)
                                    {
                                        <span class="pct">@(((double)games / (double)allDiffGames).ToPercentageString(true))</span>
                                    }
                                    else
                                    {
                                        <span class="pct">0 %</span>
                                    }
                                </div>
                                <div class="stat-pill">
                                    <div class="top-row">
                                        <span class="label">A</span>
                                        <span class="val">@ascensions</span>
                                    </div>
                                    @if (allDiffAscensions > 0)
                                    {
                                        <span class="pct">@(((double)ascensions / (double)allDiffAscensions).ToPercentageString(true))</span>
                                    }
                                    else
                                    {
                                        <span class="pct">0 %</span>
                                    }
                                </div>
                            </div>
                        </td>
                        
                    }

                    @{
                        string? darkeningClassTotal = allDiffGames > 0 ? null : "text-muted";
                    }

                    <td class="w-role text-center matrix-border-start border-bottom-0 @darkeningClassTotal">
                        <h5>@(allDiffGames > 0 ? ((double)allDiffAscensions / (double)allDiffGames).ToPercentageString(true) : "N/A")</h5>
                        <div class="cell-stats mx-auto">
                            <div class="stat-pill">
                                <div class="top-row">
                                    <span class="label">G</span>
                                    <span class="val">@allDiffGames</span>
                                </div>
                                @if (allGamesCount > 0)
                                {
                                    <span class="pct">@(((double)allDiffGames / (double)allGamesCount).ToPercentageString(true))</span>
                                }
                                else
                                {
                                    <span class="pct">0 %</span>
                                }
                            </div>
                            <div class="stat-pill">
                                <div class="top-row">
                                    <span class="label">A</span>
                                    <span class="val">@allDiffAscensions</span>
                                </div>
                                @if (allAscensionCount > 0)
                                {
                                    <span class="pct">@(((double)allDiffAscensions / (double)allAscensionCount).ToPercentageString(true))</span>
                                }
                                else
                                {
                                    <span class="pct">0 %</span>
                                }
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td class="w-diff matrix-border-top"><h6>All Difficulties</h6></td>
                @foreach (var role in GnollHackHelper.Roles)
                {
                    long games = 0;
                    long ascensions = 0;

                    if (Model.GroupByRole != null)
                    {
                        var grouping = Model.GroupByRole.FirstOrDefault(gr => gr.Key == role);
                        if (grouping != null)
                        {
                            games = grouping.LongCount();
                        }
                    }
                    if (Model.GroupByRoleAscended != null)
                    {
                        var grouping = Model.GroupByRoleAscended.FirstOrDefault(gr => gr.Key == role);
                        if (grouping != null)
                        {
                            ascensions = grouping.LongCount();
                        }
                    }

                    string? darkeningClass = games > 0 ? null : "text-muted";

                <td class="w-role text-center matrix-border-top @darkeningClass">
                    <h5>@(games > 0 ? ((double)ascensions / (double)games).ToPercentageString(true) : "N/A")</h5>
                    <div class="cell-stats mx-auto">
                        <div class="stat-pill">
                            <div class="top-row">
                                <span class="label">G</span>
                                <span class="val">@games</span>
                            </div>
                            @if (allGamesCount > 0)
                            {
                                <span class="pct">@(((double)games / (double)allGamesCount).ToPercentageString(true))</span>
                            }
                            else
                            {
                                <span class="pct">0 %</span>
                            }
                        </div>
                        <div class="stat-pill">
                            <div class="top-row">
                                <span class="label">A</span>
                                <span class="val">@ascensions</span>
                            </div>
                            @if (allAscensionCount > 0)
                            {
                                <span class="pct">@(((double)ascensions / (double)allAscensionCount).ToPercentageString(true))</span>
                            }
                            else
                            {
                                <span class="pct">0 %</span>
                            }
                        </div>
                    </div>
                </td>
                    
                    
                }

                @{
                    string? darkeningClassAll = allGamesCount > 0 ? null : "text-muted";
                }
                <td class="w-role text-center matrix-border-start matrix-border-top @darkeningClassAll">
                    <h5>@(allGamesCount > 0 ? ((double)allAscensionCount / (double)allGamesCount).ToPercentageString(true) : "N/A")</h5>
                    <div class="cell-stats mx-auto">
                        <div class="stat-pill">
                            <div class="top-row">
                                <span class="label">G</span>
                                <span class="val">@allGamesCount</span>
                            </div>
                            <span class="pct">@(allGamesCount > 0 ? "100 %" : "0 %")</span>
                        </div>
                        <div class="stat-pill">
                            <div class="top-row">
                                <span class="label">A</span>
                                <span class="val">@allAscensionCount</span>
                            </div>
                            <span class="pct">@(allAscensionCount > 0 ? "100 %" : "0 %")</span>
                        </div>
                    </div>
                </td>
            </tr>
        </tfoot>
    </table>
    </div>
</div>

@section Styles
{
    <style>
        .matrix-border-start {
            border-left: 1px solid rgba(0, 240, 255, 0.2) !important;
        }
        .matrix-border-top {
            border-top: 1px solid rgba(0, 240, 255, 0.2) !important;
        }
        .rpg-table tfoot td {
            padding: 0.75rem 1rem;
            vertical-align: middle;
            color: #cbd5e0;
        }
        .rpg-table td h6, .rpg-table td h5 {
            color: #81e6d9;
            text-shadow: 0 0 5px rgba(0, 240, 255, 0.2);
            margin: 0;
        }
        .rpg-table td.text-muted h6, .rpg-table td.text-muted h5 {
            color: #4a5568 !important;
            text-shadow: none;
        }
        .cell-stats {
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-top: 8px;
            max-width: 65px;
        }
        .stat-pill {
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(0, 240, 255, 0.1);
            border-radius: 4px;
            padding: 3px 2px;
            font-size: 0.75rem;
            line-height: 1.2;
            text-align: center;
            box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.5);
        }
        .stat-pill .top-row {
            display: flex;
            justify-content: center;
            gap: 4px;
        }
        .stat-pill .label {
            color: #a0aec0;
            font-size: 0.7rem;
        }
        .stat-pill .val {
            color: #e2e8f0;
            font-weight: bold;
        }
        .stat-pill .pct {
            display: block;
            color: #4fd1c5;
            font-size: 0.65rem;
            margin-top: 1px;
        }
        .rpg-table td.text-muted .stat-pill {
            opacity: 0.4;
            border-color: transparent;
            box-shadow: none;
        }
        .rpg-table td.text-muted .stat-pill .val {
            color: #a0aec0;
        }
    </style>
}