@using MobileGnollHackLogger.Pages
@using System.Globalization
@model DashboardViewModel

<div>
    <h1 class="mt-3 text-center text-uppercase" style="letter-spacing: 1.5px;">
        <span class="text-warning">@Model.UserName</span> <span class="text-muted fw-light d-none d-md-inline">| Dashboard</span>
    </h1>
    <div class="text-center text-muted mt-2 dashboard-stats">
        @if (Model.Rank > 0)
        {
            <span class="me-3">Rank <strong class="text-warning">#@Model.Rank</strong></span>
        }
        <span class="me-3">Played Games: <strong class="text-white">@Model.GameLogCount</strong></span>
        <span class="me-3">Last Active: <strong class="text-white">@Model.LastActive</strong></span>
        <span>Joined: <strong class="text-white">@Model.Joined</strong></span>
    </div>
</div>

<div class="mb-4 mt-4 text-start">
    <div class="d-flex flex-wrap justify-content-center gap-2 gap-md-4 mb-4">
        <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
            <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-list-ul me-1"></i>Listing</h6>
            <div class="btn-group" role="group">
                @if (Model.ListMode != "recent")
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl("recent", Model.Mode, Model.Death)">Recent</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">Recent</span>
                }
                @if (Model.ListMode != "top")
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl("top", Model.Mode, Model.Death)">Top Scores</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">Top Scores</span>
                }
            </div>
        </div>
        <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
            <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-controller me-1"></i>Gameplay Mode</h6>
            <div class="btn-group" role="group">
                @if (!string.IsNullOrEmpty(Model.Mode))
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.ListMode, null, Model.Death)">All</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">All</span>
                }
                @foreach (var mode in Model.DisplayModes)
                {
                    @if (Model.Mode != mode)
                    {
                        <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.ListMode, mode, Model.Death)">@GnollHackHelper.Modes[mode]</a>
                    }
                    else
                    {
                        <span class="btn btn-sm btn-primary active">@GnollHackHelper.Modes[mode]</span>
                    }
                }
            </div>
        </div>
        <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
            <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-award me-1"></i>Game Type</h6>
            <div class="btn-group" role="group">
                @if (Model.TopScoreMode != TopScoreMode.Games)
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.ListMode, Model.Mode, null)">All</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">All</span>
                }
                @if (Model.TopScoreMode != TopScoreMode.Ascensions)
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.ListMode, Model.Mode, "ascended")">Ascension</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">Ascension</span>
                }
            </div>
        </div>
        <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
            <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-window me-1"></i>Layout</h6>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-primary active layout-toggle-btn" data-layout="auto"><i class="bi bi-display d-none d-sm-inline"></i> Auto</button>
                <button type="button" class="btn btn-sm btn-outline-secondary layout-toggle-btn" style="border-color: rgba(255,255,255,0.2);" data-layout="table"><i class="bi bi-table d-none d-sm-inline"></i> Table</button>
                <button type="button" class="btn btn-sm btn-outline-secondary layout-toggle-btn" style="border-color: rgba(255,255,255,0.2);" data-layout="card"><i class="bi bi-card-list d-none d-sm-inline"></i> Card</button>
            </div>
        </div>
    </div>

@if (Model.ListMode == "recent")
{
    <h2 class="text-center text-uppercase mb-3">Your Recent Games</h2>
    
    @if (Model.RecentGameLogs.Any())
    {
        <div class="rpg-leaderboard-card mb-0">
            <div class="table-responsive">
                <table id="questLogsTable" class="rpg-table" style="display:none;">
                    <thead>
                        <tr>
                            <th class="w-time">Time</th>
                            <th>Character</th>
                            <th>Class</th>
                            <th>Difficulty</th>
                            <th class="w-fit-nowrap">Score</th>
                            <th class="w-fit-nowrap">Turns</th>
                            <th class="w-death">Death</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var gameLog in Model.RecentGameLogs)
                        {
                            bool isAscended = !string.IsNullOrEmpty(gameLog.DeathText) && gameLog.DeathText.Equals("ascended", StringComparison.OrdinalIgnoreCase);
                            <tr data-id="@gameLog.Id" class="@(isAscended ? "ascended-row" : "")" style="cursor: pointer;" onclick="window.location.href='/dumplog/@gameLog.Id'">
                                <td data-label="Time" data-order="@gameLog.EndTimeUTCDate.Ticks">
                                    <div class="text-light" title="@gameLog.EndTimeUTCDate.ToString("d MMM yyyy HH:mm", CultureInfo.InvariantCulture)">@gameLog.EndTimeUTCDate.ToString("d MMM yyyy", CultureInfo.InvariantCulture) <span class="time-text">@gameLog.EndTimeUTCDate.ToString("HH:mm", CultureInfo.InvariantCulture)</span></div>
                                    <div class="text-muted-small">
                                        @(gameLog.Version)-@(gameLog.EditLevel)
                                        @if (!string.IsNullOrEmpty(gameLog.PortVersion) && !string.IsNullOrEmpty(gameLog.Platform))
                                        {
                                            <text>| @(gameLog.PortVersion + gameLog.PlatformLetter + gameLog.StoreLetter)</text>
                                        }
                                    </div>
                                </td>
                                
                                <td data-label="Character" data-order="@gameLog.CharacterName">
                                    <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.CharacterName</div>
                                </td>
                                
                                <td data-label="Class" data-order="@gameLog.RoleText">
                                    <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.RoleText</div>
                                    <div class="text-muted-small">
                                        @(gameLog.RaceText), @(gameLog.GenderText), @(gameLog.AlignmentText)
                                    </div>
                                </td>
                                
                                <td data-label="Difficulty" data-order="@gameLog.DifficultyText">
                                    <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.DifficultyText</div>
                                    <div class="text-muted-small">
                                        @(gameLog.ModeText)@if(gameLog.IsTournament){<text>, Tournament</text>}
                                    </div>
                                </td>
                                
                                <td data-label="Score" data-order="@gameLog.Points">
                                    <span class="score-text">@gameLog.Points.ToString("N0", CultureInfo.InvariantCulture)</span>
                                    @if (gameLog.ExperienceLevel != null)
                                    {
                                        <div class="text-muted-small">XL: @(gameLog.ExperienceLevel)</div>
                                    }
                                </td>
                                
                                <td data-label="Turns" data-order="@gameLog.Turns">
                                    <div class="text-light">@gameLog.Turns</div>
                                    <div class="text-muted-small">@gameLog.RealTimeSpan.ToString("c", CultureInfo.InvariantCulture)</div>
                                </td>
                                
                                <td data-label="Death" data-order="@gameLog.DeathText">
                                    <div class="text-uppercase mb-1 @(isAscended ? "fw-bold" : "")" style="color: @(isAscended ? "#ffd700" : "#ffffff"); font-size: 1.05rem; letter-spacing: 0.5px; @(isAscended ? "text-shadow: 0 0 5px rgba(255, 215, 0, 0.4);" : "")">
                                        @gameLog.DeathText
                                        @if(isAscended)
                                        {
                                            <span class="text-warning crown-icon" title="Ascended">&#x1F451;</span>
                                        }
                                        @if (!string.IsNullOrEmpty(gameLog.WhileText))
                                        {
                                            <text>while </text> @gameLog.WhileText
                                        }
                                    </div>
                                    <div class="text-muted-small text-nowrap">
                                        DL: @(gameLog.DeathLevel)/@(gameLog.MaxLevel) | HP: @(gameLog.HitPoints)/@(gameLog.MaxHitPoints) | D: @(gameLog.Deaths) | C: @(gameLog.DungeonCollapses)
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center text-muted my-4">No recent quest logs found.</div>
    }
}
else if (Model.ListMode == "top")
{
    <h2 class="text-center text-uppercase mb-3 mt-1">Your Top Scores</h2>
    
    @if (Model.TopScores != null && Model.TopScores.Count > 0)
            {
                <div class="rpg-leaderboard-card mb-0">
                    <div class="table-responsive">
                        <table id="topScoresTable" class="rpg-table" style="display:none;">
                            <thead>
                                <tr>
                                    <th class="text-center w-rank">Rank</th>
                                    <th class="w-time">Time</th>
                                    <th>Character</th>
                                    <th>Class</th>
                                    <th>Difficulty</th>
                                    <th class="w-fit-nowrap">Score</th>
                                    <th class="w-fit-nowrap">Turns</th>
                                    <th class="w-death">Death</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var scoreData in Model.TopScores)
                                {
                                    var gameLog = scoreData.Log;
                                    var displayRank = scoreData.GlobalRank;
                                    bool isAscended = !string.IsNullOrEmpty(gameLog.DeathText) && gameLog.DeathText.Equals("ascended", StringComparison.OrdinalIgnoreCase);
                                    
                                    <tr data-id="@gameLog.Id" class="@(isAscended ? "ascended-row" : "")" style="cursor: pointer;" onclick="window.location.href='/dumplog/@gameLog.Id'">
                                        <td class="text-center" data-label="Rank" data-order="@displayRank">
                                            @if (displayRank == 1)
                                            {
                                                <div class="rank-1-wrapper"><span class="rank-shield shield-gold">@displayRank</span></div>
                                            }
                                            else if (displayRank == 2)
                                            {
                                                <span class="rank-shield shield-silver">@displayRank</span>
                                            }
                                            else if (displayRank == 3)
                                            {
                                                <span class="rank-shield shield-bronze">@displayRank</span>
                                            }
                                            else
                                            {
                                                <span class="rank-shield shield-standard">@displayRank</span>
                                            }
                                        </td>
                                        
                                        <td data-label="Time" data-order="@gameLog.EndTimeUTCDate.Ticks">
                                            <div class="text-light" title="@gameLog.EndTimeUTCDate.ToString("d MMM yyyy HH:mm", CultureInfo.InvariantCulture)">@gameLog.EndTimeUTCDate.ToString("d MMM yyyy", CultureInfo.InvariantCulture) <span class="time-text">@gameLog.EndTimeUTCDate.ToString("HH:mm", CultureInfo.InvariantCulture)</span></div>
                                            <div class="text-muted-small">
                                                @(gameLog.Version)-@(gameLog.EditLevel)
                                                @if (!string.IsNullOrEmpty(gameLog.PortVersion) && !string.IsNullOrEmpty(gameLog.Platform))
                                                {
                                                    <text>| @(gameLog.PortVersion + gameLog.PlatformLetter + gameLog.StoreLetter)</text>
                                                }
                                            </div>
                                        </td>
                                        
                                        <td data-label="Character" data-order="@gameLog.CharacterName">
                                            <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.CharacterName</div>
                                        </td>
                                        
                                        <td data-label="Class" data-order="@gameLog.RoleText">
                                            <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.RoleText</div>
                                            <div class="text-muted-small">
                                                @(gameLog.RaceText), @(gameLog.GenderText), @(gameLog.AlignmentText)
                                            </div>
                                        </td>
                                        
                                        <td data-label="Difficulty" data-order="@gameLog.DifficultyText">
                                            <div class="text-white text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.DifficultyText</div>
                                            <div class="text-muted-small">
                                                @(gameLog.ModeText)@if(gameLog.IsTournament){<text>, Tournament</text>}
                                            </div>
                                        </td>
                                        
                                        <td data-label="Score" data-order="@gameLog.Points">
                                            <span class="score-text">@gameLog.Points.ToString("N0", CultureInfo.InvariantCulture)</span>
                                            @if (gameLog.ExperienceLevel != null)
                                            {
                                                <div class="text-muted-small">XL: @(gameLog.ExperienceLevel)</div>
                                            }
                                        </td>
                                        
                                        <td data-label="Turns" data-order="@gameLog.Turns">
                                            <div class="text-light">@gameLog.Turns</div>
                                            <div class="text-muted-small">@gameLog.RealTimeSpan.ToString("c", CultureInfo.InvariantCulture)</div>
                                        </td>
                                        
                                        <td data-label="Death" data-order="@gameLog.DeathText">
                                            <div class="text-uppercase mb-1 @(isAscended ? "fw-bold" : "")" style="color: @(isAscended ? "#ffd700" : "#ffffff"); font-size: 1.05rem; letter-spacing: 0.5px; @(isAscended ? "text-shadow: 0 0 5px rgba(255, 215, 0, 0.4);" : "")">
                                                @gameLog.DeathText
                                                @if(isAscended)
                                                {
                                                    <span class="text-warning crown-icon" title="Ascended">&#x1F451;</span>
                                                }
                                                @if (!string.IsNullOrEmpty(gameLog.WhileText))
                                                {
                                                    <text>while </text> @gameLog.WhileText
                                                }
                                            </div>
                                            <div class="text-muted-small text-nowrap">
                                                DL: @(gameLog.DeathLevel)/@(gameLog.MaxLevel) | HP: @(gameLog.HitPoints)/@(gameLog.MaxHitPoints) | D: @(gameLog.Deaths) | C: @(gameLog.DungeonCollapses)
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center text-muted my-4">No top scores found.</div>
            }
}
</div>
