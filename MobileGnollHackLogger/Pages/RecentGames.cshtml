@page
@using System.Globalization
@model MobileGnollHackLogger.Pages.RecentGamesModel

@{
    var modeText = "All Modes";
    if (!string.IsNullOrEmpty(Model.Mode) && GnollHackHelper.Modes.ContainsKey(Model.Mode))
    {
        modeText = GnollHackHelper.Modes[Model.Mode] + " Mode";
    }

    ViewData["Title"] = Model.Title;
    ViewData["ContainerClass"] = "xlMaxWidth";
    ViewData["MainClass"] = "xlMaxWidth";
}

<div class="rpg-header mt-3">
    <div class="ornament"></div>
    <h1 class="mb-0" style="font-family: 'Cinzel', serif;">Recent Games</h1>
    <div class="ornament"></div>
</div>
<div class="text-center rpg-subtitle">
    @Model.Title.ToUpper() | @Model.SubTitle.ToUpper()
</div>

<div class="d-flex flex-wrap justify-content-center gap-2 gap-md-4 mb-4 mt-3">
    <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
        <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-controller me-1"></i>Gameplay Mode</h6>
        <div class="btn-group" role="group">
            @if (!string.IsNullOrEmpty(Model.Mode))
            {
                <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(null, Model.Death)">All Modes</a>
            }
            else
            {
                <span class="btn btn-sm btn-primary active">All Modes</span>
            }
            @foreach (var mode in Model.DisplayModes)
            {
                @if (Model.Mode != mode)
                {
                    <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(mode, Model.Death)">@GnollHackHelper.Modes[mode]</a>
                }
                else
                {
                    <span class="btn btn-sm btn-primary active">@GnollHackHelper.Modes[mode]</span>
                }
            }
        </div>
    </div>
    <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
        <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-award me-1"></i>Game Type</h6>
        <div class="btn-group" role="group">
            @if (Model.RecentGamesMode != RecentGamesMode.Ascensions)
            {
                <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.Mode, "ascended")">Ascensions</a>
            }
            else
            {
                <span class="btn btn-sm btn-primary active">Ascensions</span>
            }
            @if (Model.RecentGamesMode != RecentGamesMode.Games)
            {
                <a class="btn btn-sm btn-outline-secondary" style="border-color: rgba(255,255,255,0.2);" href="@Model.GetUrl(Model.Mode, null)">Games</a>
            }
            else
            {
                <span class="btn btn-sm btn-primary active">Games</span>
            }
        </div>
    </div>
    <div class="text-center p-2 rounded" style="background: rgba(15, 20, 30, 0.6); border: 1px solid rgba(0, 240, 255, 0.1);">
        <h6 class="text-uppercase text-muted mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-window me-1"></i>Layout</h6>
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-sm btn-primary active layout-toggle-btn" data-layout="auto"><i class="bi bi-display d-none d-sm-inline"></i> Auto</button>
            <button type="button" class="btn btn-sm btn-outline-secondary layout-toggle-btn" style="border-color: rgba(255,255,255,0.2);" data-layout="table"><i class="bi bi-table d-none d-sm-inline"></i> Table</button>
            <button type="button" class="btn btn-sm btn-outline-secondary layout-toggle-btn" style="border-color: rgba(255,255,255,0.2);" data-layout="card"><i class="bi bi-card-list d-none d-sm-inline"></i> Cards</button>
        </div>
    </div>
</div>

@if (Model.GameLogs != null && Model.GameLogs.Count > 0)
{
    <div class="rpg-leaderboard-card">
        <div class="table-responsive">
            <table id="topScoreTable" class="rpg-table" style="display:none;">
                <thead>
                    <tr>
                        <th>Time & Version</th>
                        <th>Account</th>
                        <th>Class & Details</th>
                        <th style="width: 12%;">Points</th>
                        <th style="width: 8%;">Turns</th>
                        <th style="width: 30%; min-width: 280px;">Result</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var gameLog in Model.GameLogs)
                    {
                        bool isAscended = !string.IsNullOrEmpty(gameLog.DeathText) && gameLog.DeathText.Equals("ascended", StringComparison.OrdinalIgnoreCase);
                        <tr data-id="@gameLog.Id" class="@(isAscended ? "ascended-row" : "")">
                            <td data-label="Time & Version" data-order="@gameLog.EndTimeUTCDate.Ticks">
                                <div class="text-light">@gameLog.EndTimeUTCDate.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture)</div>
                                <div class="text-muted-small">
                                    v@(gameLog.Version)-@(gameLog.EditLevel)
                                    @if (!string.IsNullOrEmpty(gameLog.PortVersion) && !string.IsNullOrEmpty(gameLog.Platform))
                                    {
                                        <text>| @(gameLog.PortVersion + gameLog.PlatformLetter + gameLog.StoreLetter)</text>
                                    }
                                </div>
                            </td>
                            
                            <td data-label="Account" data-order="@gameLog.Name">
                                <div>
                                    <div class="text-white fw-bold text-uppercase" style="letter-spacing: 0.5px; font-size: 1.05rem;">@gameLog.Name</div>
                                    <div class="text-muted-small">
                                        Character: @(gameLog.CharacterName)
                                    </div>
                                </div>
                            </td>
                            
                            <td data-label="Class & Details" data-order="@gameLog.RoleText">
                                <div class="text-uppercase text-light" style="letter-spacing: 0.5px;">@gameLog.RoleText</div>
                                <div class="text-muted-small">
                                    @(gameLog.RaceText), @(gameLog.GenderText), @(gameLog.AlignmentText)
                                </div>
                                <div class="text-muted-small">
                                    @gameLog.DifficultyText, @(gameLog.ModeText)@if(gameLog.IsTournament){<text>, Tournament</text>}
                                </div>
                            </td>
                            
                            <td data-label="Points" data-order="@gameLog.Points">
                                <div class="d-flex align-items-center">
                                    <span class="score-text mb-0">@gameLog.Points.ToString("N0", CultureInfo.InvariantCulture)</span>
                                    @if(isAscended)
                                    {
                                        <span class="ms-2 text-warning" title="Ascended" style="font-size: 1.25rem; text-shadow: 0 0 5px rgba(255,215,0,0.5); transform: translateY(-3px);">&#x1F451;</span>
                                    }
                                </div>
                            </td>
                            
                            <td data-label="Turns" data-order="@gameLog.Turns">
                                <div class="text-light">@gameLog.Turns</div>
                                <div class="text-muted-small">@gameLog.RealTimeSpan.ToString("c", CultureInfo.InvariantCulture)</div>
                            </td>
                            
                            <td data-label="Result" data-order="@gameLog.DeathText">
                                <div class="text-uppercase mb-1 @(isAscended ? "fw-bold" : "")" style="color: @(isAscended ? "#ffd700" : "#ffffff"); font-size: 1.05rem; letter-spacing: 0.5px; @(isAscended ? "text-shadow: 0 0 5px rgba(255, 215, 0, 0.4);" : "")">
                                    @gameLog.DeathText
                                    @if (!string.IsNullOrEmpty(gameLog.WhileText))
                                    {
                                        <text>while </text> @gameLog.WhileText
                                    }
                                </div>
                                <div class="text-muted-small">
                                    DL: @(gameLog.DeathLevel)/@(gameLog.MaxLevel) | HP: @(gameLog.HitPoints)/@(gameLog.MaxHitPoints)
                                </div>
                                <div class="text-muted-small">
                                    Deaths: @(gameLog.Deaths) | Crashes: @(gameLog.DungeonCollapses)
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <h5 class="text-center">No Matching Data</h5>
}

@section Styles
{
    <link rel="stylesheet" href="~/lib/datatables/dist/datatables.min.css" asp-append-version="true" />
    <style>
        .ascended-row > td {
            background-color: rgba(255, 215, 0, 0.08) !important;
            border-bottom-color: rgba(255, 215, 0, 0.2) !important;
        }
        .rpg-table tbody tr.ascended-row:hover > td {
            background-color: rgba(255, 215, 0, 0.15) !important;
        }
    </style>
}

@section Scripts
{
    <script src="~/lib/datatables/dist/datatables.min.js"></script>
    <script>
        $("#topScoreTable>tbody").on("click", "tr", function () {
            var id = $(this).attr("data-id");
            var href = "/dumplog/" + id;
            window.location.href = href;
        });
        $("#topScoreTable").dataTable({
            order: [],
            autoWidth: false
        }).show();
    </script>
}