@using MobileGnollHackLogger.Data
@inject SignInManager<ApplicationUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-row flex-md-column justify-content-start overflow-x-auto text-nowrap pb-2 mb-3">
    <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">Profile</a></li>
    <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">Email</a></li>
    <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">Password</a></li>
    @if (hasExternalLogins)
    {
        <li id="external-logins" class="nav-item me-2 me-md-0 mb-md-2"><a id="external-login" class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">External logins</a></li>
    }
@*     <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">Two-factor authentication</a></li> *@
    <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">Personal data</a></li>
    <li class="nav-item me-2 me-md-0 mb-md-2"><a class="nav-link @ManageNavPages.JunetHackNavClass(ViewContext)" id="junethack" asp-page="./JunetHack">Junethack</a></li>
</ul>
