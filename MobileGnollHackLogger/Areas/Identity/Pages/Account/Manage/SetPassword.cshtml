@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="login-box manage-login-box">
    <form id="set-password-form" method="post" class="login-form disable-button-on-submit">
        <div class="login-form-inner">
            <div class="login-header text-center">
                <h3 class="hero-title">Set your password</h3>
                <div class="ornament"></div>
            </div>
            
            <p class="text-info text-center mb-4">
                You do not have a local username/password for this site. Add a local
                account so you can log in without an external login.
            </p>

            <partial name="_StatusMessage" for="StatusMessage" />

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            
            <div class="input-group mb-4 login-input-group">
                <span class="input-group-text" title="New password"><i class="bi bi-key-fill"></i></span>
                <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="New password" title="New password" />
            </div>
            <span asp-validation-for="Input.NewPassword" class="text-danger mb-3 d-block"></span>

            <div class="input-group mb-4 login-input-group">
                <span class="input-group-text" title="Confirm new password"><i class="bi bi-key-fill"></i></span>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="Confirm new password" title="Confirm new password" />
            </div>
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger mb-3 d-block"></span>

            <div class="login-button-container mb-3 mt-4">
                <button type="submit" class="btn btn-fantasy-login w-100">
                    <span>SET PASSWORD</span>
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
