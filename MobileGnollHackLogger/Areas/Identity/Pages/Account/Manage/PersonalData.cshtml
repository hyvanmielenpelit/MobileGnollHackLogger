@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="login-box manage-login-box">
    <div class="login-form">
        <div class="login-form-inner">
            <div class="login-header text-center">
                <h3 class="hero-title">@ViewData["Title"]</h3>
                <div class="ornament"></div>
            </div>

            <p class="text-white mb-4">Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
            <p class="text-danger mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
            </p>

            <form id="download-data" asp-page="DownloadPersonalData" method="post" class="mb-4">
                <div class="login-button-container">
                    <button class="btn btn-fantasy-login w-100" type="submit">
                        <span>DOWNLOAD</span>
                    </button>
                </div>
            </form>

            <div class="login-button-container">
                <a id="delete" asp-page="DeletePersonalData" class="btn btn-fantasy-danger w-100">
                    <span>DELETE</span>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
