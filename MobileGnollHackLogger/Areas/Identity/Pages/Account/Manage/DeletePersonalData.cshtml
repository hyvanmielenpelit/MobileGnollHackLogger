@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="login-box manage-login-box">
    <form id="delete-user" method="post" class="login-form disable-button-on-submit">
        <div class="login-form-inner">
            <div class="login-header text-center">
                <h3 class="hero-title">@ViewData["Title"]</h3>
                <div class="ornament"></div>
            </div>

            <p class="text-danger mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
            </p>

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            @if (Model.RequirePassword)
            {
                <div class="input-group mb-4 login-input-group">
                    <span class="input-group-text" title="Password"><i class="bi bi-key-fill"></i></span>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Password" title="Password" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger mb-3 d-block text-start"></span>
            }

            <div class="login-button-container mt-4">
                <button class="btn btn-fantasy-danger w-100" type="submit">
                    <span>DELETE ACCOUNT</span>
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
