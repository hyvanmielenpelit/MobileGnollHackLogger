@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Reset password";
    ViewData["MainClass"] = "main-narrow";
}

<div class="row login-page-container">
    <div class="center-box login-box">
        <section>
            <div class="login-header text-center">
                <h1 class="hero-title">GnollHack</h1>
                <div class="ornament"></div>
                <p class="login-subtitle">RESET YOUR PASSWORD</p>
            </div>

            <form method="post" class="login-form disable-button-on-submit">
                <div class="login-form-inner">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    <input asp-for="Input.Code" type="hidden" />

                    <div class="input-group mb-4 login-input-group">
                        <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Email" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>

                    <div class="input-group mb-4 login-input-group">
                        <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Password" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>

                    <div class="input-group mb-4 login-input-group">
                        <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" />
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

                    <div class="login-button-container text-center mb-3">
                        <button type="submit" class="btn btn-fantasy-login w-100">
                            <span>RESET PASSWORD</span>
                        </button>
                    </div>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
