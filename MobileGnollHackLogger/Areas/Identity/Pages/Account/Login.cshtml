@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    ViewData["MainClass"] = "main-narrow";
}

<div class="row login-page-container">
    <div class="center-box login-box">
        <section>
            <div class="login-header text-center">
                <h1 class="login-title">GNOLLHACK</h1>
                <div class="ornament"></div>
                <p class="login-subtitle">GET AN ACCOUNT FOR THE DUNGEONS OF DOOM</p>
            </div>

            <form id="account" method="post" class="login-form">
                <div class="login-form-inner">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                
                <div class="input-group mb-4 login-input-group">
                    <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                    <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" placeholder="User Name" />
                </div>
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
                
                <div class="input-group mb-2 login-input-group">
                    <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Password" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>

                <div class="d-flex justify-content-end mb-4">
                    <a id="forgot-password" class="forgot-link" asp-page="./ForgotPassword">Forgot Password?</a>
                </div>

                <div class="login-button-container text-center mb-4">
                    <button id="login-submit" type="submit" class="btn btn-fantasy-login w-100">
                        <span>LOG IN</span>
                    </button>
                </div>

                <div class="d-flex justify-content-center mb-4">
                    <div class="checkbox login-checkbox">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            @Html.DisplayNameFor(m => m.Input.RememberMe)
                        </label>
                    </div>
                </div>

                <div class="text-center my-4">
                    <p class="signup-text">
                        Don't have an account? <a class="signup-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Sign Up</a>
                    </p>
                </div>
                
                    <div class="text-center mt-2">
                        <p>
                            <a id="resend-confirmation" class="subtle-link" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                        </p>
                    </div>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
