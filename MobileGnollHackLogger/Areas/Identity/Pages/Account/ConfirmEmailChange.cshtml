@page
@model ConfirmEmailChangeModel
@{
    ViewData["Title"] = "Confirm email change";
    ViewData["MainClass"] = "main-narrow";
}

<div class="row login-page-container">
    <div class="center-box login-box">
        <section>
            <div class="login-header text-center">
                <h1 class="hero-title">GNOLLHACK</h1>
                <div class="ornament"></div>
                <p class="login-subtitle">EMAIL CHANGE CONFIRMATION</p>
            </div>

            @if (Model.IsSuccess)
            {
                <div class="login-form">
                    <div class="login-form-inner">
                        <div class="success-message-container">
                            <i class="bi bi-check-circle-fill success-icon"></i>
                            <p class="success-text">@Model.StatusMessage</p>
                        </div>
                        <div class="text-center mb-0">
                            <p class="signup-text mb-0">
                                <a class="signup-link" asp-page="./Manage/Index">Back to Profile</a>
                            </p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="login-form">
                    <div class="login-form-inner">
                        <div class="text-center mb-4">
                            <i class="bi bi-exclamation-triangle-fill text-danger mb-2" style="font-size: 3rem;"></i>
                            <p class="text-danger fw-bold" style="font-size: 1.1rem;">@Model.StatusMessage</p>
                        </div>
                        <div class="text-center mb-0">
                            <p class="signup-text mb-0">
                                <a class="signup-link" asp-page="./Manage/Email">Back to Manage Email</a>
                            </p>
                        </div>
                    </div>
                </div>
            }
        </section>
    </div>
</div>
